{
  "name": "vinculo",
  "version": "0.0.0",
  "private": true,
  "description": "Vínculo — memória clínica inteligente para psicólogos (Cloudflare)",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm -w @vinculo/api run dev",
    "dev:web": "npm -w @vinculo/web run dev",
    "db:generate": "npm -w @vinculo/api run db:generate",
    "db:apply:local": "npm -w @vinculo/api run db:apply:local",
    "db:apply:remote": "npm -w @vinculo/api run db:apply:remote",
    "deploy:api": "npm -w @vinculo/api run deploy",
    "deploy:web": "npm -w @vinculo/web run deploy",
    "typecheck": "npm -w @vinculo/api run typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
