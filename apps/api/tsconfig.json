{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": ["@cloudflare/workers-types"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@vinculo/db": ["../../packages/db/src/index.ts"],
      "@vinculo/db/schema": ["../../packages/db/src/schema.ts"]
    }
  },
  "include": ["src/**/*.ts"]
}
